---
import Layout from '../layouts/Layout.astro';
import NotFoundApp from '../components/apps/NotFoundApp';

const title = 'Página no encontrada | INGECON S.A.S.';
const description = 'La página que buscas no existe. Vuelve al inicio o explora nuestros servicios e historial.';
---

<Layout title={title} description={description} path="/404" locale="es" noindex>
  <NotFoundApp client:load />
</Layout>
