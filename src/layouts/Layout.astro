---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

export interface Props {
  title: string;
  description: string;
  path: string;
  noindex?: boolean;
  ogImage?: string;
  schema?: object;
  locale?: 'es' | 'en';
}

const SITE_URL = 'https://ingecon.com.co';
const DEFAULT_OG = `${SITE_URL}/og-image.jpg`;

const {
  title,
  description,
  path,
  noindex = false,
  ogImage = DEFAULT_OG,
  schema,
  locale = 'es',
} = Astro.props;

const canonical = `${SITE_URL}${path}`;
const ogLocale = locale === 'es' ? 'es_CO' : 'en_US';
const altLocale = locale === 'es' ? 'en_US' : 'es_CO';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      'name': 'INGENIERÍA Y CONSULTORÍA INGECON S.A.S.',
      'alternateName': 'INGECON S.A.S.',
      'url': `${SITE_URL}/`,
      'logo': {
        '@type': 'ImageObject',
        'url': `${SITE_URL}/images/logo-ingecon-CUG5jr9Z.webp`,
        'caption': 'INGECON S.A.S.',
      },
      'foundingDate': '2001',
      'description': 'Firma colombiana especializada en interventoría, consultoría y gerencia de proyectos de infraestructura pública.',
      'taxID': '810.002.747-0',
      'knowsAbout': [
        'Interventoría de obras civiles',
        'Interventoría de carreteras y vías',
        'Interventoría de aeropuertos',
        'Interventoría de túneles',
        'Interventoría de obras de urbanismo',
        'Consultoría en ingeniería',
        'Gerencia de proyectos de infraestructura pública',
      ],
      'areaServed': { '@type': 'Country', 'name': 'Colombia' },
      'address': {
        '@type': 'PostalAddress',
        'streetAddress': 'Calle 148 No. 7G-42, Barrio Cedritos',
        'addressLocality': 'Bogotá',
        'addressRegion': 'Cundinamarca',
        'postalCode': '110131',
        'addressCountry': 'CO',
      },
      'contactPoint': {
        '@type': 'ContactPoint',
        'telephone': '+57-323-307-2588',
        'contactType': 'customer service',
        'email': 'info@ingecon.com.co',
        'availableLanguage': ['Spanish', 'English'],
      },
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${SITE_URL}/#localbusiness`,
      'name': 'INGECON S.A.S.',
      'image': `${SITE_URL}/images/logo-ingecon-CUG5jr9Z.webp`,
      'url': `${SITE_URL}/`,
      'telephone': '+57-323-307-2588',
      'email': 'info@ingecon.com.co',
      'priceRange': '$$$',
      'address': {
        '@type': 'PostalAddress',
        'streetAddress': 'Calle 148 No. 7G-42, Barrio Cedritos',
        'addressLocality': 'Bogotá',
        'addressRegion': 'Cundinamarca',
        'postalCode': '110131',
        'addressCountry': 'CO',
      },
      'geo': { '@type': 'GeoCoordinates', 'latitude': 4.7317, 'longitude': -74.0321 },
      'openingHoursSpecification': [{
        '@type': 'OpeningHoursSpecification',
        'dayOfWeek': ['Monday','Tuesday','Wednesday','Thursday','Friday'],
        'opens': '08:00',
        'closes': '17:30',
      }],
      'parentOrganization': { '@id': `${SITE_URL}/#organization` },
    },
  ],
};
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#6a9a10" />

  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,follow" />}

  <link rel="canonical" href={canonical} />

  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  {/* Open Graph */}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="INGECON S.A.S. — Interventoría e Ingeniería" />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:locale:alternate" content={altLocale} />
  <meta property="og:site_name" content="INGECON S.A.S." />

  {/* Twitter Card */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  {/* Schema.org */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />
  {schema && <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />}

  {/* Preload critical font (latin subset only) */}
  <link rel="preload" as="font" type="font/woff2" href="/fonts/open-sans-latin-wght-normal.woff2" crossorigin />

  {/* LCP hero image preload — AVIF responsive */}
  {path === '/' && (
    <link
      rel="preload"
      as="image"
      type="image/avif"
      imagesrcset="/images/hero-640.avif 640w, /images/hero-1024.avif 1024w, /images/hero-1600.avif 1600w"
      imagesizes="100vw"
      fetchpriority="high"
    />
  )}

  <ClientRouter />
</head>
<body class="bg-white text-gray-700 font-sans leading-normal tracking-tight">
  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
  <slot />
  <Analytics />
  <SpeedInsights />
</body>
</html>
